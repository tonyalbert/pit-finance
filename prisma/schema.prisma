// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TagType {
  INCOME
  EXPENSE
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tags                Tag[]
  incomes             Income[]
  expenses            Expense[]
  creditors           Creditor[]
  passwordResetTokens PasswordResetToken[]
  fixedExpenses       FixedExpense[]
  tickets             Ticket[]
  ticketMessages      TicketMessage[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  type      TagType
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes       Income[]
  expenses      Expense[]
  fixedExpenses FixedExpense[]

  @@unique([userId, name, type])
  @@index([userId, type])
}

model Creditor {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses      Expense[]
  fixedExpenses FixedExpense[]

  @@unique([userId, name])
  @@index([userId])
}

model Income {
  id        String   @id @default(uuid())
  source    String
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime
  tagId     String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag? @relation(fields: [tagId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}

model Expense {
  id                 String     @id @default(uuid())
  item               String
  amount             Decimal    @db.Decimal(12, 2)
  date               DateTime
  isPaid             Boolean    @default(false)
  installmentGroupId String?
  installmentNumber  Int?
  installmentTotal   Int?
  tagId              String?
  creditorId         String?
  userId             String
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag      Tag?     @relation(fields: [tagId], references: [id], onDelete: SetNull)
  creditor       Creditor?     @relation(fields: [creditorId], references: [id], onDelete: SetNull)
  fixedExpense   FixedExpense? @relation(fields: [fixedExpenseId], references: [id], onDelete: SetNull)
  fixedExpenseId String?

  @@index([userId, date])
  @@index([userId, installmentGroupId])
  @@index([userId, creditorId])
  @@index([fixedExpenseId])
}

model FixedExpense {
  id         String   @id @default(uuid())
  name       String
  amount     Decimal  @db.Decimal(12, 2)
  dayOfMonth Int
  tagId      String?
  creditorId String?
  userId     String
  isActive   Boolean  @default(true)
  startDate  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag      Tag?      @relation(fields: [tagId], references: [id], onDelete: SetNull)
  creditor Creditor? @relation(fields: [creditorId], references: [id], onDelete: SetNull)
  expenses Expense[]

  @@index([userId])
  @@index([userId, isActive])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum TicketCategory {
  TECHNICAL
  FINANCIAL
  ACCOUNT
  OTHER
}

model Ticket {
  id          String         @id @default(uuid())
  title       String
  description String
  status      TicketStatus   @default(OPEN)
  category    TicketCategory @default(OTHER)
  userId      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id        String   @id @default(uuid())
  content   String
  ticketId  String
  userId    String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
}
